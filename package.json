{
	"name": "better-diagram",
	"version": "0.1.0",
	"description": "Edit SVG-backed diagrams from Markdown in Obsidian.",
	"main": "dist/main.js",
	"type": "module",
	"scripts": {
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest run",
		"obsidian:check": "node scripts/obsidian/check-cli.mjs",
		"obsidian:vault:create": "node scripts/obsidian/create-vault.mjs",
		"obsidian:plugin:install": "node scripts/obsidian/install-plugin.mjs",
		"obsidian:vault:open": "node scripts/obsidian/open-vault.mjs",
		"obsidian:plugin:reload": "node scripts/obsidian/reload-plugin.mjs"
	},
	"keywords": [
		"obsidian",
		"diagram",
		"svg",
		"markdown"
	],
	"author": "qiudeng",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.15.17",
		"@types/react": "19.2.1",
		"@types/react-dom": "19.2.1",
		"esbuild": "0.25.5",
		"obsidian": "latest",
		"typescript": "^5.8.3",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"react": "19.2.1",
		"react-dom": "19.2.1",
		"tldraw": "^5.2.5"
	}
}
